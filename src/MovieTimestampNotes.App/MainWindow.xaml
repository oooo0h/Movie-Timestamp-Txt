<Window x:Class="MovieTimestampNotes.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="电影时间戳文本框"
        Width="680" Height="738" MinWidth="380" MinHeight="100"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="True"
        FontFamily="Microsoft YaHei UI" TextOptions.TextFormattingMode="Display">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" CornerRadius="12"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Color x:Key="SurfaceColor">#F20A0F1D</Color>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="CardBrush" Color="#C9141C2E"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#E21A253A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#C90D1424"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#38E8FF"/>
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#2638E8FF"/>
        <SolidColorBrush x:Key="VioletBrush" Color="#9B7BFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F2F7FF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8291AA"/>
        <SolidColorBrush x:Key="LineBrush" Color="#3A60718E"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF627D"/>

        <LinearGradientBrush x:Key="WindowGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FA080D18" Offset="0"/>
            <GradientStop Color="#F20E1628" Offset="0.58"/>
            <GradientStop Color="#F40B1020" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#38E8FF" Offset="0"/>
            <GradientStop Color="#7C8CFF" Offset="0.58"/>
            <GradientStop Color="#B76EFF" Offset="1"/>
        </LinearGradientBrush>
        <DrawingBrush x:Key="GridPattern" TileMode="Tile" Viewport="0,0,28,28" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent" Geometry="M 0,28 L 28,28 M 28,0 L 28,28">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#1038E8FF" Thickness="0.6"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#B51B2940"/>
            <Setter Property="BorderBrush" Value="#4A60718E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E0263B58"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E22D5B74"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2938E8FF"/>
            <Setter Property="BorderBrush" Value="#9938E8FF"/>
            <Setter Property="Foreground" Value="#EAFEFF"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="#8038E8FF"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputChrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="InputChrome" Property="Background" Value="#F0121C30"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputChrome" Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#172033"/>
            <Setter Property="Background" Value="#E8EAF4FF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#2A33445D"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Grid x:Name="PART_Track" ClipToBounds="True">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome" Background="#6E58718F" CornerRadius="3" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="#B938E8FF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InvisibleScrollButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="#50101A2B" CornerRadius="4" Margin="1">
                <Track x:Name="PART_Track" IsDirectionReversed="True" Orientation="Vertical">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollThumbStyle}" MinHeight="18"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Border Background="#50101A2B" CornerRadius="4" Margin="1">
                <Track x:Name="PART_Track" IsDirectionReversed="False" Orientation="Horizontal">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollThumbStyle}" MinWidth="18"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource InvisibleScrollButton}" Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="9"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2238E8FF"/>
            <Setter Property="RowBackground" Value="#35152235"/>
            <Setter Property="AlternatingRowBackground" Value="#5517243A"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#A8192941"/>
            <Setter Property="Foreground" Value="#8CA3C3"/>
            <Setter Property="BorderBrush" Value="#334D6584"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="9,8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder" Background="{StaticResource WindowGradient}" BorderBrush="#6638E8FF"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="#003B57" BlurRadius="26" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Border Background="{StaticResource GridPattern}" Opacity="0.55" IsHitTestVisible="False"/>
            <Border Width="220" Height="220" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-130,-100,0" CornerRadius="110" Background="#1838E8FF" IsHitTestVisible="False">
                <Border.Effect><BlurEffect Radius="35"/></Border.Effect>
            </Border>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition x:Name="CompactRow" Height="80"/>
                    <RowDefinition x:Name="DetailRow" Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#C7080D18" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Grid Width="18" Height="18" Margin="0,0,7,0">
                            <Border Width="11" Height="11" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5"
                                    Background="#2638E8FF" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform>
                            </Border>
                            <Ellipse Width="4" Height="4" Fill="{StaticResource AccentBrush}"/>
                        </Grid>
                        <TextBlock Text="电影时间戳" Foreground="{StaticResource TextBrush}" FontSize="12"
                                   FontWeight="SemiBold"/>
                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="3" Background="#1F38E8FF">
                            <TextBlock x:Name="FileNameText" Text="NO FILE" Foreground="#7FC8D8" FontSize="9"
                                       TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                        </Border>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Content="—" Foreground="#8EA0B9"
                            Click="MinimizeButton_Click"/>
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Content="×" Foreground="#FF7F96"
                            Click="CloseButton_Click"/>
                    <Border Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom" Background="{StaticResource AccentGradient}" Opacity="0.55"/>
                </Grid>

                <Grid Grid.Row="1" Margin="8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="138"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="82"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="TimelineButton" Grid.Column="0" Style="{StaticResource PrimaryButton}"
                            FontSize="14" Content="▶" Padding="0" Margin="3,0" ToolTip="开始/暂停电影时间"
                            Click="TimelineButton_Click"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0,8,0">
                        <TextBlock x:Name="CurrentTimeText" Text="00:00:00 / 01:30:00" Foreground="#E8F8FF"
                                   FontFamily="Consolas" FontSize="12"/>
                        <ProgressBar x:Name="TimelineProgress" Height="2" Minimum="0" Maximum="1" Margin="0,4,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="独立电影时间轴" Foreground="#53627A" FontSize="10"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="2,3,2,0">
                        <TextBox x:Name="InputTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" IsEnabled="False" Padding="9,6"
                                 ToolTip="输入感想；Enter 提交，Shift+Enter 换行"
                                 TextChanged="InputTextBox_TextChanged" PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
                        <TextBlock Text="记录此刻的想法…" Foreground="#66738A" Margin="10,0" VerticalAlignment="Center"
                                   FontSize="12"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="4,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="5" Height="5" Fill="#5FF5BA" Margin="0,0,4,0"/>
                            <TextBlock x:Name="MicStatusText" Text="语音加载中" Foreground="#9EADC2" FontSize="10"
                                       TextTrimming="CharacterEllipsis" MaxWidth="66"/>
                        </StackPanel>
                        <ProgressBar x:Name="MicLevelProgress" Height="2" Minimum="0" Maximum="1" Margin="5,4,5,0"
                                     Foreground="#5FF5BA"/>
                    </StackPanel>
                    <Button x:Name="ExpandButton" Grid.Column="4" Style="{StaticResource IconButton}" Content="⌃"
                            FontSize="14" Foreground="{StaticResource AccentBrush}" ToolTip="收起/展开"
                            VerticalAlignment="Center" Click="ExpandButton_Click"/>
                </Grid>

                <Grid x:Name="ExpandedPanel" Grid.Row="2" Margin="11,2,11,11">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,2,0,7">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Content="＋ 新建记录" Click="NewFileButton_Click"/>
                            <Button Content="⌁ 打开记录" Click="OpenFileButton_Click"/>
                            <Button Content="↺ 重置计时" Click="ResetButton_Click"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="独立电影时间轴" Foreground="#64728A"
                                   FontSize="11" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Margin="8,0"/>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="#354D6584"
                            BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,7">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="68"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="62"/><ColumnDefinition Width="126"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="影片名称"/>
                            <TextBox x:Name="MovieTitleTextBox" Grid.Column="1" IsEnabled="False" LostFocus="MovieTitleTextBox_LostFocus"/>
                            <Label Grid.Column="2" Content="总时长"/>
                            <TextBox x:Name="DurationTextBox" Grid.Column="3" Text="01:30:00" ToolTip="HH:MM:SS"
                                     FontFamily="Consolas"/>
                            <Button Grid.Column="4" Content="应用" Click="ApplyDurationButton_Click"/>

                            <Label Grid.Row="1" Content="时间校准" Margin="0,5,0,0"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBox x:Name="CalibrationTextBox" Text="00:00:00" ToolTip="HH:MM:SS" Width="126"
                                         FontFamily="Consolas"/>
                                <Button x:Name="CalibrateButton" Content="校准" Click="CalibrateButton_Click"/>
                            </StackPanel>
                            <Label Grid.Row="1" Grid.Column="2" Content="麦克风" Margin="0,5,0,0"/>
                            <ComboBox x:Name="MicrophoneComboBox" Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2"
                                      DisplayMemberPath="Name" Margin="3,8,3,3"
                                      SelectionChanged="MicrophoneComboBox_SelectionChanged"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="{StaticResource CardBrush}" BorderBrush="#354D6584"
                            BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,7">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="88"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.ColumnSpan="5" Orientation="Horizontal" Margin="2,0,0,7">
                                <TextBlock Text="全局快捷键" Foreground="{StaticResource AccentBrush}"
                                           FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="  窗口不在前台时仍可使用" Foreground="#71819A" FontSize="11"/>
                            </StackPanel>
                            <Label Grid.Row="1" Content="暂停 / 继续"/><TextBox x:Name="TimelineHotkeyTextBox" Grid.Row="1" Grid.Column="1" FontFamily="Consolas"/>
                            <Label Grid.Row="1" Grid.Column="2" Content="按住说话"/><TextBox x:Name="PushToTalkHotkeyTextBox" Grid.Row="1" Grid.Column="3"
                                                                                             FontFamily="Consolas" ToolTip="支持单键，例如 V；应用运行时该键会被全局占用"/>
                            <Label Grid.Row="2" Content="开关说话"/><TextBox x:Name="ToggleVoiceHotkeyTextBox" Grid.Row="2" Grid.Column="1" FontFamily="Consolas"/>
                            <Label Grid.Row="2" Grid.Column="2" Content="聚焦输入"/><TextBox x:Name="FocusInputHotkeyTextBox" Grid.Row="2" Grid.Column="3" FontFamily="Consolas"/>
                            <Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="4" Style="{StaticResource PrimaryButton}"
                                    Content="应用快捷键" Margin="8,3,3,3" Click="ApplyHotkeysButton_Click"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Background="#A80E1626" BorderBrush="#354D6584" BorderThickness="1"
                            CornerRadius="8" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Grid Grid.Row="0" Background="#9A142139">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="●" Foreground="{StaticResource VioletBrush}" FontSize="9" Margin="0,0,7,0"/>
                                    <TextBlock Text="感想记录" Foreground="#C9D5E5" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="  可直接修改文字，时间戳保持不变" Foreground="#71819A" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                            <DataGrid x:Name="NotesDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column" CellEditEnding="NotesDataGrid_CellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="开始" Binding="{Binding StartLabel}" IsReadOnly="True" Width="90"/>
                                    <DataGridTextColumn Header="结束" Binding="{Binding EndLabel}" IsReadOnly="True" Width="90"/>
                                    <DataGridTextColumn Header="来源" Binding="{Binding SourceLabel}" IsReadOnly="True" Width="58"/>
                                    <DataGridTextColumn Header="感想记录" Binding="{Binding Text, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                    <DataGridTemplateColumn Header="" Width="62">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="删除" Foreground="#FF8CA0" BorderBrush="#5FFF627D" Background="#20FF627D"
                                                        Tag="{Binding}" Click="DeleteNoteButton_Click" Padding="6,3"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Background="#75101726" BorderBrush="#283D536F" BorderThickness="1"
                            CornerRadius="6" Margin="0,7,0,0" Padding="9,6">
                        <DockPanel>
                            <TextBlock Text="状态" Foreground="{StaticResource AccentBrush}" FontSize="10"
                                       FontWeight="SemiBold" Margin="0,0,9,0"/>
                            <TextBlock x:Name="StatusText" Text="请先新建或打开一个 TXT 记录文件。"
                                       Foreground="#8FA0B9" FontSize="11" TextWrapping="Wrap"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
