<Window x:Class="MovieTimestampNotes.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="电影时间戳文本框"
        Width="660" Height="690" MinWidth="560"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" Topmost="True" ShowInTaskbar="True">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F51B1D23"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#2B2E38"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#77A9FF"/>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5F6FA"/>
            <Setter Property="Background" Value="#343844"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F5F6FA"/>
            <Setter Property="Background" Value="#292C35"/>
            <Setter Property="BorderBrush" Value="#454A59"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="7,5"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#C9CDD8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder" Background="{StaticResource PanelBrush}" BorderBrush="#505564"
            BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#252832" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="●" Foreground="#77A9FF" FontSize="10" Margin="0,0,7,0"/>
                    <TextBlock Text="电影时间戳文本框" Foreground="#F5F6FA" FontWeight="SemiBold"/>
                    <TextBlock x:Name="FileNameText" Text="  未打开记录" Foreground="#858B99" Margin="8,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="—" Width="38" Height="30" Click="MinimizeButton_Click"/>
                <Button Grid.Column="2" Content="×" Width="38" Height="30" Background="#71343A" Click="CloseButton_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="148"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="42"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="TimelineButton" Grid.Column="0" FontSize="18" Content="▶" ToolTip="开始/暂停电影时间"
                        Click="TimelineButton_Click"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                    <TextBlock x:Name="CurrentTimeText" Text="00:00:00 / 01:30:00" Foreground="White"
                               FontFamily="Consolas" FontSize="13" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="TimelineProgress" Height="4" Minimum="0" Maximum="1" Margin="0,8,0,0"
                                 Foreground="{StaticResource AccentBrush}" Background="#353945"/>
                </StackPanel>
                <TextBox x:Name="InputTextBox" Grid.Column="2" Margin="4" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" IsEnabled="False"
                         ToolTip="输入感想；Enter 提交，Shift+Enter 换行"
                         TextChanged="InputTextBox_TextChanged" PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock x:Name="MicStatusText" Text="语音加载中" Foreground="#AEB4C2" FontSize="11"
                               TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <ProgressBar x:Name="MicLevelProgress" Height="5" Minimum="0" Maximum="1" Margin="5,7"
                                 Foreground="#63D9A0" Background="#353945"/>
                </StackPanel>
                <Button x:Name="ExpandButton" Grid.Column="4" Content="⌃" FontSize="16" ToolTip="收起/展开"
                        Click="ExpandButton_Click"/>
            </Grid>

            <Grid x:Name="ExpandedPanel" Grid.Row="2" Margin="11,0,11,11">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,7">
                    <Button Content="新建记录" Click="NewFileButton_Click"/>
                    <Button Content="打开记录" Click="OpenFileButton_Click"/>
                    <Button Content="重置计时" Click="ResetButton_Click"/>
                    <TextBlock Text="电影由外部播放器播放，本工具仅记录时间和感想。" Foreground="#858B99"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="影片名称"/>
                    <TextBox x:Name="MovieTitleTextBox" Grid.Column="1" IsEnabled="False" LostFocus="MovieTitleTextBox_LostFocus"/>
                    <Label Grid.Column="2" Content="总时长"/>
                    <TextBox x:Name="DurationTextBox" Grid.Column="3" Text="01:30:00" ToolTip="HH:MM:SS"/>
                    <Button Grid.Column="4" Content="应用" Click="ApplyDurationButton_Click"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="当前校准"/>
                    <TextBox x:Name="CalibrationTextBox" Grid.Column="1" Text="00:00:00" ToolTip="HH:MM:SS"/>
                    <Button x:Name="CalibrateButton" Grid.Column="2" Content="校准" Click="CalibrateButton_Click"/>
                    <Label Grid.Column="3" Content="麦克风"/>
                    <ComboBox x:Name="MicrophoneComboBox" Grid.Column="4" DisplayMemberPath="Name"
                              SelectionChanged="MicrophoneComboBox_SelectionChanged"/>
                </Grid>

                <GroupBox Grid.Row="3" Header="全局快捷键（窗口不在前台时仍可用）" Foreground="#C9CDD8" Margin="0,8,0,5">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="85"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="85"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <Label Content="暂停/继续"/><TextBox x:Name="TimelineHotkeyTextBox" Grid.Column="1"/>
                        <Label Grid.Column="2" Content="按住说话"/><TextBox x:Name="PushToTalkHotkeyTextBox" Grid.Column="3"
                                                                         ToolTip="支持单键，例如 V；应用运行时该键会被全局占用"/>
                        <Label Grid.Row="1" Content="开关说话"/><TextBox x:Name="ToggleVoiceHotkeyTextBox" Grid.Row="1" Grid.Column="1"/>
                        <Label Grid.Row="1" Grid.Column="2" Content="聚焦输入"/><TextBox x:Name="FocusInputHotkeyTextBox" Grid.Row="1" Grid.Column="3"/>
                        <Button Grid.RowSpan="2" Grid.Column="4" Content="应用快捷键" Click="ApplyHotkeysButton_Click"/>
                    </Grid>
                </GroupBox>

                <TextBlock Grid.Row="4" Text="已记录感想（可直接修改文字，时间范围保持不变）" Foreground="#C9CDD8" Margin="3,5"/>

                <DataGrid x:Name="NotesDataGrid" Grid.Row="5" AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="#242730"
                          Foreground="#F2F3F7" BorderBrush="#454A59" RowBackground="#242730"
                          AlternatingRowBackground="#292D37" CellEditEnding="NotesDataGrid_CellEditEnding">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="开始" Binding="{Binding StartLabel}" IsReadOnly="True" Width="88"/>
                        <DataGridTextColumn Header="结束" Binding="{Binding EndLabel}" IsReadOnly="True" Width="88"/>
                        <DataGridTextColumn Header="来源" Binding="{Binding SourceLabel}" IsReadOnly="True" Width="55"/>
                        <DataGridTextColumn Header="感想" Binding="{Binding Text, UpdateSourceTrigger=LostFocus}" Width="*"/>
                        <DataGridTemplateColumn Header="" Width="58">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="删除" Tag="{Binding}" Click="DeleteNoteButton_Click" Padding="5,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="StatusText" Grid.Row="6" Text="请先新建或打开一个 TXT 记录文件。"
                           Foreground="#AEB4C2" Margin="3,7,3,0" TextWrapping="Wrap"/>
            </Grid>
        </Grid>
    </Border>
</Window>
